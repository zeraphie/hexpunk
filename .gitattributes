# Force LF for all text files so Mac ↔ Windows checkouts stay consistent.
* text=auto eol=lf

# Windows scripts need CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Treat common binaries as binary so git doesn't munge them.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
