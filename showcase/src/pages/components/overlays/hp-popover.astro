---
import Layout from "../../../layouts/Layout.astro";
import ComponentDocs from "../../../components/ComponentDocs.astro";
---

<Layout title="hp-popover">
  <ComponentDocs title="hp-popover">
    <p slot="description">
      Anchored floating panel — click a trigger to open a panel positioned against it. Side
      / align preference with automatic flip on overflow, click-outside and Escape dismiss,
      focus restoration to the trigger on close. Unlike
      <code>&lt;hp-tooltip&gt;</code>, the panel body can contain focusable controls.
    </p>

    <hp-demo caption="Click trigger to open">
      <hp-popover side="bottom" align="start">
        <hp-button>open</hp-button>
        <div slot="content">
          <strong>Quick info</strong>
          <p style="margin: 8px 0 0">Anchored to the trigger; flips if the viewport edge gets in the way.</p>
        </div>
      </hp-popover>

      <hp-code slot="code" language="jsx">{`import "@hexpunk/core";

export default () => (
  <>
    <hp-popover side="bottom" align="start">
      <hp-button>open</hp-button>

      <div slot="content">
        <strong>Quick info</strong>
        <p>...</p>
      </div>
    </hp-popover>
  </>
);`}</hp-code>
    </hp-demo>

    <Fragment slot="intent">
      <h2>Accessibility</h2>
      <p>
        Trigger auto-stamps <code>aria-haspopup="dialog"</code> and toggles
        <code>aria-expanded</code>. Panel exposes <code>role="dialog"</code>. Click outside or
        Escape dismisses; focus returns to the trigger on close (when focus was inside the
        panel).
      </p>
    </Fragment>
  </ComponentDocs>
</Layout>
