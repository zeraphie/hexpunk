---
import Layout from "../../layouts/Layout.astro";
import { SITEMAP, isLeaf } from "../../sitemap.ts";

// Derive category data from the sitemap (single source of truth).
// Walk the Components branch's children → category branches → leaf entries.
interface CategoryItem {
  name: string; // hp-cell etc.
  path: string; // /components/<cat>/<name>
}
interface Category {
  name: string;
  q: number;
  r: number;
  items: CategoryItem[];
}

// Hand-tuned axial positions per category — clusters spaced 3 axial
// units apart in both directions. The cluster bbox is ~5 axial units
// wide / tall (4 col-steps + cell width), so 3-unit spacing means
// neighbour clusters interleave at the corners. Empty honeycomb-
// corner space in each cluster's ring-2 region lets them tile
// cleanly without their hexes literally overlapping.
// Layout: 4×3 grid of categories aligned vertically in pixel space
// (q on odd r rows shifts by -r/2 to compensate the axial-to-pixel
// x = col_step * (q + r/2) offset).
const POSITIONS: Record<string, { q: number; r: number }> = {
  Primitives: { q: 0, r: 0 },
  Forms: { q: 3, r: 0 },
  Status: { q: 6, r: 0 },
  Loading: { q: 9, r: 0 },
  Layout: { q: -2, r: 3 },
  Images: { q: 1, r: 3 },
  Navigation: { q: 4, r: 3 },
  Overlays: { q: 7, r: 3 },
  Messaging: { q: -3, r: 6 },
  Tether: { q: 0, r: 6 },
  Unfold: { q: 3, r: 6 },
  Deprecated: { q: 6, r: 6 },
};

const componentsBranch = SITEMAP.find(
  (n) => !isLeaf(n) && n.title === "Components"
);
const categories: Category[] = !componentsBranch || isLeaf(componentsBranch)
  ? []
  : componentsBranch.children
      .filter((c): c is { title: string; children: typeof SITEMAP } => !isLeaf(c))
      .map((c) => {
        const pos = POSITIONS[c.title] ?? { q: 0, r: 0 };
        return {
          name: c.title.toLowerCase(),
          q: pos.q,
          r: pos.r,
          items: c.children.filter(isLeaf).map((leaf) => ({
            name: leaf.title,
            path: leaf.path,
          })),
        };
      });
---

<Layout title="Components" fullWidth>
  <div class="components-page">
    <header class="components-header">
      <h1>Components</h1>
      <p class="components-tagline">
        Every <code>&lt;hp-*&gt;</code> element on a single hex grid. Drag a cluster's
        centre to slide it; tap an outer hex to open its docs.
      </p>
      <label class="component-filter">
        <input
          type="search"
          id="component-search"
          placeholder="Filter by component name..."
          autocomplete="off"
          spellcheck="false"
        />
      </label>
    </header>

    <hp-grid draggable id="components-grid" class="components-grid">
      <hp-background></hp-background>
      {categories.map((cat) => (
        <hp-cluster
          layout="honeycomb"
          q={cat.q}
          r={cat.r}
          drag-handle=":first-child"
        >
          <hp-cell variant="anchor" filled tabindex="0">{cat.name}</hp-cell>
          {cat.items.map((item) => (
            <a href={item.path} class="component-link">
              <hp-cell variant="action" tabindex="0">{item.name}</hp-cell>
            </a>
          ))}
        </hp-cluster>
      ))}
    </hp-grid>
  </div>

  <style>
    .components-page {
      display: flex;
      flex-direction: column;
      /* Fill the viewport minus the fixed navbar so the grid extends
       * all the way to the bottom. Header above the grid takes its
       * natural size; grid claims the rest via flex: 1. */
      height: calc(100vh - var(--hp-navbar-height));
    }

    .components-header {
      padding: var(--hp-md) var(--hp-xl);
      border-bottom: 1px solid var(--hp-outline-faint);
    }

    .components-header h1 {
      margin: 0 0 var(--hp-xs);
    }

    .components-tagline {
      color: var(--hp-on-surface-variant);
      margin: 0 0 var(--hp-md);
    }

    .component-filter {
      display: block;
      max-width: 32rem;
    }

    .component-filter input {
      width: 100%;
      padding: var(--hp-sm) var(--hp-md);
      font-size: var(--hp-typo-body-md-font-size);
    }

    /* Grid claims all remaining vertical space, fills width edge-to-
     * edge (the page's main has already dropped its padding via
     * Layout.astro fullWidth mode). */
    .components-grid {
      flex: 1 1 0;
      min-height: 0;
      width: 100%;
    }

    .component-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .component-link:hover,
    .component-link:focus-visible {
      text-decoration: none;
      color: inherit;
    }

    [hidden] {
      display: none !important;
    }
  </style>

  <script>
    // Filter logic: walk every <a class="component-link"> descendant of
    // the grid and toggle `hidden` based on a substring match against
    // the wrapped hp-cell's text content. Cluster centres (variant=
    // anchor filled, NOT wrapped in <a>) stay always visible — the
    // category labels are part of the page's structural map, not
    // filterable items.
    const search = document.querySelector<HTMLInputElement>("#component-search");
    const grid = document.querySelector<HTMLElement>("#components-grid");
    if (search && grid) {
      const links = Array.from(grid.querySelectorAll<HTMLAnchorElement>("a.component-link"));
      const apply = () => {
        const query = search.value.trim().toLowerCase();
        for (const link of links) {
          const cell = link.querySelector("hp-cell");
          const text = (cell?.textContent ?? "").toLowerCase();
          link.hidden = query.length > 0 && !text.includes(query);
        }
      };
      search.addEventListener("input", apply);
      // Run once on load so the initial render is consistent if the
      // browser restored a value from autocomplete (rare with
      // autocomplete="off" but harmless).
      apply();
    }
  </script>
</Layout>
