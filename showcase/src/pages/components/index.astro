---
import Layout from "../../layouts/Layout.astro";
import { SITEMAP, isLeaf } from "../../sitemap.ts";

// Mirror Layout.astro's baseUrl helper so links resolve under the
// configured BASE_URL (e.g. /hexpunk on the GitHub Pages deployment).
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
function href(path: string): string {
  return path === "/" ? baseUrl || "/" : `${baseUrl}${path}`;
}

// Derive category data from the sitemap (single source of truth).
// Walk the Components branch's children → category branches → leaf entries.
interface CategoryItem {
  name: string; // hp-cell etc.
  path: string; // /components/<cat>/<name>
}
interface Category {
  name: string;
  items: CategoryItem[];
}

// Axial positions are computed at runtime by <hp-grid layout="rows">
// — every cluster reports its filled-hex extent via data-fill-cells
// and hp-grid greedy-packs them with a 1-cell gap. Adding / removing
// components in sitemap.ts auto-reflows.
const componentsBranch = SITEMAP.find(
  (n) => !isLeaf(n) && n.title === "Components"
);
const categories: Category[] = !componentsBranch || isLeaf(componentsBranch)
  ? []
  : componentsBranch.children
      .filter((c): c is { title: string; children: typeof SITEMAP } => !isLeaf(c))
      .map((c) => ({
        name: c.title.toLowerCase(),
        items: c.children.filter(isLeaf).map((leaf) => ({
          name: leaf.title,
          path: leaf.path,
        })),
      }));
---

<Layout title="Components" fullWidth>
  <div class="components-page">
    <header class="components-header">
      <h1>Components</h1>
      <p class="components-tagline">
        Every <code>&lt;hp-*&gt;</code> element on a single hex grid. Drag a cluster's
        centre to slide it; tap an outer hex to open its docs.
      </p>
      <label class="component-filter">
        <input
          type="search"
          id="component-search"
          placeholder="Filter by component name..."
          autocomplete="off"
          spellcheck="false"
        />
      </label>
    </header>

    <hp-grid draggable layout="rows" id="components-grid" class="components-grid">
      {categories.map((cat) => (
        <hp-cluster layout="honeycomb" drag-handle=":first-child">
          <hp-cell variant="anchor" filled tabindex="0">{cat.name}</hp-cell>
          {cat.items.map((item) => (
            <a href={href(item.path)} class="component-link">
              <hp-cell variant="action" tabindex="0">{item.name}</hp-cell>
            </a>
          ))}
        </hp-cluster>
      ))}
    </hp-grid>
  </div>

  <style>
    .components-page {
      display: flex;
      flex-direction: column;
      /* Fill the viewport minus the fixed navbar so the grid extends
       * all the way to the bottom. Header above the grid takes its
       * natural size; grid claims the rest via flex: 1. */
      height: calc(100vh - var(--hp-navbar-height));
    }

    /* Web Awesome-style centered intro: title, tagline, and filter
     * stack vertically with breathing room. The header isn't full-
     * width content — it caps at a comfortable reading width and
     * centres horizontally. */
    .components-header {
      padding: var(--hp-xxl) var(--hp-xl) var(--hp-xl);
      border-bottom: 1px solid var(--hp-outline-faint);
      text-align: center;
    }

    .components-header h1 {
      margin: 0 0 var(--hp-md);
    }

    .components-tagline {
      color: var(--hp-on-surface-variant);
      margin: 0 auto var(--hp-xl);
      max-width: 48rem;
    }

    .component-filter {
      display: block;
      max-width: 32rem;
      margin: 0 auto;
    }

    .component-filter input {
      width: 100%;
      padding: var(--hp-sm) var(--hp-md);
      font-size: var(--hp-typo-body-md-font-size);
      text-align: center;
    }

    /* Grid claims all remaining vertical space, fills width edge-to-
     * edge (the page's main has already dropped its padding via
     * Layout.astro fullWidth mode). */
    .components-grid {
      flex: 1 1 0;
      min-height: 0;
      width: 100%;
    }

    .component-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .component-link:hover,
    .component-link:focus-visible {
      text-decoration: none;
      color: inherit;
    }

    [hidden] {
      display: none !important;
    }
  </style>

  <script>
    // Filter logic walks every <a class="component-link"> descendant
    // of the grid and toggles `hidden` based on a substring match
    // against the wrapped hp-cell's text content. When a cluster's
    // entire set of links is filtered out, the cluster itself goes
    // hidden too — leaving a stranded anchor centre isn't useful.
    // After a 300ms debounce we call `grid.pack()` so the layout
    // reflows around just the visible clusters (the FFD packer
    // skips hidden children).
    const search = document.querySelector<HTMLInputElement>("#component-search");
    const grid = document.querySelector<HTMLElement & { pack?: () => void }>(
      "#components-grid",
    );
    if (search && grid) {
      const links = Array.from(
        grid.querySelectorAll<HTMLAnchorElement>("a.component-link"),
      );
      const clusters = Array.from(grid.querySelectorAll<HTMLElement>("hp-cluster"));
      let repackTimer: ReturnType<typeof setTimeout> | null = null;

      const apply = () => {
        const query = search.value.trim().toLowerCase();
        for (const link of links) {
          const cell = link.querySelector("hp-cell");
          const text = (cell?.textContent ?? "").toLowerCase();
          link.hidden = query.length > 0 && !text.includes(query);
        }
        for (const cluster of clusters) {
          const clusterLinks = cluster.querySelectorAll<HTMLAnchorElement>(
            "a.component-link",
          );
          const anyVisible = Array.from(clusterLinks).some((l) => !l.hidden);
          cluster.hidden = !anyVisible;
        }
        // Debounce the repack so we don't reflow on every keystroke.
        // 300ms feels right for type-and-pause filtering.
        if (repackTimer) {
          clearTimeout(repackTimer);
        }
        repackTimer = setTimeout(() => {
          grid.pack?.();
        }, 300);
      };

      search.addEventListener("input", apply);
      // Run once on load so the initial render is consistent if the
      // browser restored a value from autocomplete (rare with
      // autocomplete="off" but harmless).
      apply();
    }
  </script>
</Layout>
